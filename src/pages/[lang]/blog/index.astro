---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getTagPalette } from '../../../config/tags';

export function getStaticPaths() {
  return [{ params: { lang: 'ja' } }, { params: { lang: 'en' } }];
}

const lang = Astro.params.lang as 'ja' | 'en';
const isJa = lang === 'ja';
const otherLang = lang === 'ja' ? 'en' : 'ja';
function getRouteKey(id: string, fallbackSlug: string) {
  const match = id.match(/(.*)\/(ja|en)\.(md|mdx)$/);
  return match ? match[1] : fallbackSlug;
}

const allPosts = await getCollection('blog');
const posts = allPosts
  .filter((post) => post.data.lang === lang)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const externalEntries = (await getCollection('external'))
  .filter((entry) => entry.data.lang === lang)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const translationLangsByKey = allPosts.reduce(
  (acc, post) => {
    const key = getRouteKey(post.id, post.slug);
    const current = acc.get(key) ?? new Set<'ja' | 'en'>();
    current.add(post.data.lang);
    acc.set(key, current);
    return acc;
  },
  new Map<string, Set<'ja' | 'en'>>()
);

const sourceLabel: Record<'blog' | 'qiita' | 'zenn' | 'note' | 'devto', string> = {
  blog: 'Blog',
  qiita: 'Qiita',
  zenn: 'Zenn',
  note: 'Note',
  devto: 'dev.to'
};

const items = [
  ...posts.map((post) => ({
    routeKey: getRouteKey(post.id, post.slug),
    title: post.data.title,
    description: post.data.description,
    date: post.data.pubDate,
    href: `/${lang}/blog/${getRouteKey(post.id, post.slug)}/`,
    source: 'blog' as const,
    translated: (translationLangsByKey.get(getRouteKey(post.id, post.slug))?.size ?? 0) >= 2,
    external: false,
    tags: post.data.tags
  })),
  ...externalEntries.map((entry) => ({
    title: entry.data.title,
    description: entry.data.description,
    date: entry.data.pubDate,
    href: entry.data.url,
    source: entry.data.source,
    translated: null,
    external: true,
    tags: entry.data.tags
  }))
].sort((a, b) => b.date.getTime() - a.date.getTime());
---

<BaseLayout
  title={isJa ? 'ブログ一覧' : 'Blog'}
  description={isJa ? '日本語記事と外部投稿の一覧です。' : 'A list of blog posts and external writings.'}
  lang={lang}
  languageSwitchHref={`/${otherLang}/blog/`}
>
  <h1>{isJa ? 'ブログ一覧' : 'Blog'}</h1>
  <ul class="post-list">
    {items.map((item) => (
      <li class="post-card">
        <a
          class="post-link"
          href={item.href}
          target={item.external ? '_blank' : undefined}
          rel={item.external ? 'noopener noreferrer' : undefined}
        >
          <span class="post-title-row">
            <span class="post-title">{item.title}</span>
            <span class="post-arrow" aria-hidden="true">{item.external ? '↗' : '→'}</span>
          </span>
        </a>
        <p class="post-description">{item.description}</p>
        <div class="muted">{item.date.toISOString().slice(0, 10)}</div>
        <div class="badges">
          <span class={`badge source-${item.source}`}>{sourceLabel[item.source]}</span>
          {item.translated !== null && (
            <span class="badge translation">
              {item.translated
                ? (isJa ? '対訳あり' : 'Translated')
                : (isJa ? '対訳なし' : 'Untranslated')}
            </span>
          )}
          {item.tags.map((tag) => (
            <span
              class="tag-chip"
              style={`--tag-chip-bg:${getTagPalette(tag).bg};--tag-chip-border:${getTagPalette(tag).border};--tag-chip-text:${getTagPalette(tag).text};`}
            >
              #{tag}
            </span>
          ))}
        </div>
      </li>
    ))}
  </ul>
  <style>
    .post-list {
      list-style: none;
      padding: 0;
      margin: 1.2rem 0 0;
      display: grid;
      gap: 0.9rem;
    }
    .post-card {
      border: 1px solid var(--card-border);
      border-radius: 12px;
      background: var(--card-bg);
      padding: 0.8rem 0.9rem;
      transition: transform 180ms ease, box-shadow 180ms ease, border-color 180ms ease;
      transform: translateY(0);
      box-shadow: 0 0 0 rgba(0, 0, 0, 0);
    }
    .post-link { text-decoration: none; }
    .post-title-row {
      display: flex;
      justify-content: space-between;
      gap: 0.8rem;
      align-items: baseline;
    }
    .post-title { font-weight: 600; text-decoration: underline; }
    .post-arrow { color: var(--arrow-color); transition: transform 180ms ease, color 180ms ease; }
    .post-description {
      margin: 0.45rem 0 0.35rem;
      color: var(--muted);
      font-size: 0.94rem;
    }
    .post-card:hover {
      transform: translateY(-3px);
      border-color: var(--card-hover-border);
      box-shadow: var(--card-shadow);
    }
    .post-card:hover .post-arrow {
      transform: translateX(3px);
      color: var(--arrow-hover-color);
    }
    .badges { display: flex; gap: 0.4rem; margin-top: 0.15rem; flex-wrap: wrap; }
    .badge {
      display: inline-block;
      padding: 0.1rem 0.45rem;
      border-radius: 999px;
      font-size: 0.76rem;
      border: 1px solid var(--badge-border);
      background: var(--badge-bg);
      color: var(--badge-text);
    }
    .source-blog { background: var(--source-blog-bg); }
    .source-qiita { background: var(--source-qiita-bg); border-color: var(--source-qiita-border); color: var(--source-qiita-text); }
    .source-zenn { background: var(--source-zenn-bg); border-color: var(--source-zenn-border); color: var(--source-zenn-text); }
    .source-note { background: var(--source-note-bg); border-color: var(--source-note-border); color: var(--source-note-text); }
    .source-devto { background: var(--source-devto-bg); border-color: var(--source-devto-border); color: var(--source-devto-text); }
    .translation { background: var(--translation-bg); border-color: var(--translation-border); color: var(--translation-text); }
    .tag-chip {
      display: inline-block;
      padding: 0.15rem 0.52rem;
      border-radius: 999px;
      font-size: 0.74rem;
      letter-spacing: 0.01em;
      border: 1px solid var(--tag-chip-border, var(--tag-border));
      background: var(--tag-chip-bg, var(--tag-bg));
      color: var(--tag-chip-text, var(--tag-text));
      box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.35);
      transition: transform 120ms ease, border-color 120ms ease;
    }
    .post-card:hover .tag-chip {
      transform: translateY(-1px);
      border-color: color-mix(in srgb, var(--tag-border) 70%, var(--text));
    }
  </style>
</BaseLayout>
